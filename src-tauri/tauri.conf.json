{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Venice Media Local",
  "version": "26.6.5",
  "identifier": "community.venice.media.local",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Venice Media Local",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 540,
        "backgroundColor": "#1e1f22",
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost; media-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost https://api.venice.ai"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Neko Legends",
    "copyright": "Copyright © Neko Legends",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "GraphicsAndDesign",
    "shortDescription": "Local Venice media generator",
    "longDescription": "A local desktop app for generating images, video, music, sound effects, and voice through the Venice API."
  }
}
