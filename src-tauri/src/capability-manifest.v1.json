{
  "schemaVersion": "1.0",
  "provider": {
    "id": "venice-media-local",
    "instanceId": "",
    "displayName": "Venice Media Local",
    "version": "",
    "machineId": "",
    "kind": "media"
  },
  "transport": {
    "type": "http",
    "baseUrl": "",
    "manifestUrl": ""
  },
  "health": {
    "mode": "poll",
    "path": "/api/v1/health",
    "intervalSeconds": 30,
    "timeoutSeconds": 5
  },
  "capabilities": [
    {
      "id": "media.image.generate",
      "revision": "1",
      "title": "Generate images",
      "description": "Generate one or more images with a Venice image model and save them locally.",
      "inputSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "required": ["model", "prompt"],
        "properties": {
          "model": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "prompt": { "type": "string", "minLength": 1 },
          "negativePrompt": { "type": "string" },
          "aspectRatio": { "type": "string" },
          "resolution": { "type": "string" },
          "variants": { "type": "integer", "minimum": 1, "maximum": 4 },
          "steps": { "type": "integer", "minimum": 1 },
          "cfgScale": { "type": "number" },
          "seed": { "type": "integer", "minimum": 0 },
          "hideWatermark": { "type": "boolean" },
          "safeMode": { "type": "boolean" },
          "format": { "type": "string" },
          "navigate": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "outputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "array", "items": { "$ref": "#/$defs/mediaResult" }, "$defs": { "mediaResult": { "type": "object", "required": ["id", "kind", "name", "mimeType", "dataUrl", "metadata"], "properties": { "id": { "type": "string" }, "kind": { "type": "string" }, "name": { "type": "string" }, "mimeType": { "type": "string" }, "dataUrl": { "type": "string" }, "filePath": { "type": "string" }, "metadata": { "type": "object" }, "text": { "type": "string" } } } } },
      "invocation": { "method": "POST", "path": "/api/v1/generate-image" },
      "sideEffects": ["network", "consume-resource", "credential-use", "write-provider-files"],
      "riskClass": "external-resource",
      "approvalClass": "bounded-creative",
      "progress": { "mode": "none" },
      "cancellation": { "supported": false },
      "artifacts": [{ "role": "output", "kinds": ["image"], "mimeTypes": ["image/png", "image/jpeg", "image/webp"], "deliveryModes": ["data-url", "provider-path"] }]
    },
    {
      "id": "media.image.edit",
      "revision": "1",
      "title": "Edit images",
      "description": "Edit or combine one or more source images with a Venice image-edit model.",
      "inputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "required": ["model", "prompt", "images"], "properties": { "model": { "type": "string", "minLength": 1 }, "prompt": { "type": "string", "minLength": 1 }, "images": { "type": "array", "minItems": 1, "items": { "type": "string", "contentEncoding": "base64" } }, "aspectRatio": { "type": "string" }, "resolution": { "type": "string" }, "safeMode": { "type": "boolean" }, "navigate": { "type": "boolean" } }, "additionalProperties": false },
      "outputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "$ref": "#/$defs/mediaResult", "$defs": { "mediaResult": { "type": "object", "required": ["id", "kind", "name", "mimeType", "dataUrl", "metadata"], "properties": { "id": { "type": "string" }, "kind": { "type": "string" }, "name": { "type": "string" }, "mimeType": { "type": "string" }, "dataUrl": { "type": "string" }, "filePath": { "type": "string" }, "metadata": { "type": "object" } } } } },
      "invocation": { "method": "POST", "path": "/api/v1/edit-image" },
      "sideEffects": ["network", "consume-resource", "credential-use", "write-provider-files"],
      "riskClass": "external-resource",
      "approvalClass": "bounded-creative",
      "progress": { "mode": "none" },
      "cancellation": { "supported": false },
      "artifacts": [{ "role": "output", "kinds": ["image"], "mimeTypes": ["image/png", "image/jpeg", "image/webp"], "deliveryModes": ["data-url", "provider-path"] }]
    },
    {
      "id": "media.image.background-remove",
      "revision": "1",
      "title": "Remove image background",
      "description": "Remove the background from an image and save the result locally.",
      "inputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "required": ["sourceImage"], "properties": { "sourceImage": { "type": "string", "contentEncoding": "base64" }, "navigate": { "type": "boolean" } }, "additionalProperties": false },
      "outputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object" },
      "invocation": { "method": "POST", "path": "/api/v1/remove-background" },
      "sideEffects": ["network", "consume-resource", "credential-use", "write-provider-files"],
      "riskClass": "external-resource",
      "approvalClass": "bounded-creative",
      "progress": { "mode": "none" },
      "cancellation": { "supported": false },
      "artifacts": [{ "role": "output", "kinds": ["image"], "mimeTypes": ["image/png"], "deliveryModes": ["data-url", "provider-path"] }]
    },
    {
      "id": "media.image.upscale",
      "revision": "1",
      "title": "Upscale image",
      "description": "Upscale an image by 2x or 4x and save the result locally.",
      "inputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "required": ["sourceImage", "scale"], "properties": { "sourceImage": { "type": "string", "contentEncoding": "base64" }, "scale": { "type": "integer", "enum": [2, 4] }, "navigate": { "type": "boolean" } }, "additionalProperties": false },
      "outputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object" },
      "invocation": { "method": "POST", "path": "/api/v1/upscale-image" },
      "sideEffects": ["network", "consume-resource", "credential-use", "write-provider-files"],
      "riskClass": "external-resource",
      "approvalClass": "bounded-creative",
      "progress": { "mode": "none" },
      "cancellation": { "supported": false },
      "artifacts": [{ "role": "output", "kinds": ["image"], "mimeTypes": ["image/png", "image/jpeg", "image/webp"], "deliveryModes": ["data-url", "provider-path"] }]
    },
    {
      "id": "media.video.generate",
      "revision": "1",
      "title": "Generate video",
      "description": "Queue a Venice video generation and poll its retrieval endpoint until complete.",
      "inputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "required": ["model", "prompt"], "properties": { "model": { "type": "string", "minLength": 1 }, "prompt": { "type": "string", "minLength": 1 }, "negativePrompt": { "type": "string" }, "sourceImage": { "type": "string" }, "sourceVideo": { "type": "string" }, "duration": { "type": "string" }, "durationSeconds": { "type": "string" }, "resolution": { "type": "string" }, "aspectRatio": { "type": "string" }, "upscaleFactor": { "type": "integer" }, "navigate": { "type": "boolean" } }, "additionalProperties": false },
      "outputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "required": ["queueId", "status", "progressLabel", "downloadUrl", "raw"], "properties": { "queueId": { "type": "string" }, "status": { "type": "string" }, "progressLabel": { "type": "string" }, "downloadUrl": { "type": "string" }, "raw": {} } },
      "invocation": { "method": "POST", "path": "/api/v1/queue-video", "poll": { "method": "POST", "path": "/api/v1/retrieve-video", "operationIdField": "queueId" } },
      "sideEffects": ["network", "consume-resource", "credential-use", "write-provider-files"],
      "riskClass": "external-resource",
      "approvalClass": "bounded-creative",
      "progress": { "mode": "poll", "path": "/api/v1/retrieve-video", "intervalMs": 2000 },
      "cancellation": { "supported": false },
      "artifacts": [{ "role": "output", "kinds": ["video"], "mimeTypes": ["video/mp4", "video/webm"], "deliveryModes": ["data-url", "provider-path"] }]
    },
    {
      "id": "media.audio.music.generate",
      "revision": "1",
      "title": "Generate music",
      "description": "Queue a Venice music generation and poll its retrieval endpoint until complete.",
      "inputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "required": ["model", "prompt"], "properties": { "model": { "type": "string", "minLength": 1 }, "prompt": { "type": "string", "minLength": 1 }, "negativePrompt": { "type": "string" }, "duration": { "type": "string" }, "durationSeconds": { "type": "string" }, "forceInstrumental": { "type": "boolean" }, "lyricsPrompt": { "type": "string" }, "lyricsOptimizer": { "type": "boolean" }, "navigate": { "type": "boolean" } }, "additionalProperties": false },
      "outputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "required": ["queueId", "status", "progressLabel", "downloadUrl", "raw"] },
      "invocation": { "method": "POST", "path": "/api/v1/queue-music", "poll": { "method": "POST", "path": "/api/v1/retrieve-audio", "operationIdField": "queueId" } },
      "sideEffects": ["network", "consume-resource", "credential-use", "write-provider-files"],
      "riskClass": "external-resource",
      "approvalClass": "bounded-creative",
      "progress": { "mode": "poll", "path": "/api/v1/retrieve-audio", "intervalMs": 2000 },
      "cancellation": { "supported": false },
      "artifacts": [{ "role": "output", "kinds": ["audio", "music"], "mimeTypes": ["audio/mpeg", "audio/wav", "audio/ogg", "audio/flac"], "deliveryModes": ["data-url", "provider-path"] }]
    },
    {
      "id": "media.audio.sfx.generate",
      "revision": "1",
      "title": "Generate sound effect",
      "description": "Queue a Venice sound-effect generation and poll its retrieval endpoint until complete.",
      "inputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "required": ["model", "prompt"], "properties": { "model": { "type": "string", "minLength": 1 }, "prompt": { "type": "string", "minLength": 1 }, "negativePrompt": { "type": "string" }, "duration": { "type": "string" }, "durationSeconds": { "type": "string" }, "navigate": { "type": "boolean" } }, "additionalProperties": false },
      "outputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "required": ["queueId", "status", "progressLabel", "downloadUrl", "raw"] },
      "invocation": { "method": "POST", "path": "/api/v1/queue-sfx", "poll": { "method": "POST", "path": "/api/v1/retrieve-audio", "operationIdField": "queueId", "fixedFields": { "kind": "sfx" } } },
      "sideEffects": ["network", "consume-resource", "credential-use", "write-provider-files"],
      "riskClass": "external-resource",
      "approvalClass": "bounded-creative",
      "progress": { "mode": "poll", "path": "/api/v1/retrieve-audio", "intervalMs": 2000 },
      "cancellation": { "supported": false },
      "artifacts": [{ "role": "output", "kinds": ["audio", "sound-effect"], "mimeTypes": ["audio/mpeg", "audio/wav", "audio/ogg", "audio/flac"], "deliveryModes": ["data-url", "provider-path"] }]
    },
    {
      "id": "media.voice.generate",
      "revision": "1",
      "title": "Generate voice",
      "description": "Generate speech audio with a Venice voice model and save it locally.",
      "inputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "required": ["model", "input"], "properties": { "model": { "type": "string", "minLength": 1 }, "input": { "type": "string", "minLength": 1 }, "voice": { "type": "string" }, "speed": { "type": "number" }, "language": { "type": "string" }, "responseFormat": { "type": "string" }, "stylePrompt": { "type": "string" }, "temperature": { "type": "number" }, "topP": { "type": "number" }, "navigate": { "type": "boolean" } }, "additionalProperties": false },
      "outputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object" },
      "invocation": { "method": "POST", "path": "/api/v1/generate-speech" },
      "sideEffects": ["network", "consume-resource", "credential-use", "write-provider-files"],
      "riskClass": "external-resource",
      "approvalClass": "bounded-creative",
      "progress": { "mode": "none" },
      "cancellation": { "supported": false },
      "artifacts": [{ "role": "output", "kinds": ["audio", "voice"], "mimeTypes": ["audio/mpeg", "audio/wav", "audio/ogg", "audio/flac"], "deliveryModes": ["data-url", "provider-path"] }]
    },
    {
      "id": "media.transcribe",
      "revision": "1",
      "title": "Transcribe audio",
      "description": "Transcribe supplied audio with a Venice speech-to-text model.",
      "inputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "required": ["model", "audio"], "properties": { "model": { "type": "string", "minLength": 1 }, "audio": { "type": "string", "contentEncoding": "base64" }, "fileName": { "type": "string" }, "mimeType": { "type": "string" }, "responseFormat": { "type": "string" }, "timestamps": { "type": "boolean" }, "language": { "type": "string" }, "navigate": { "type": "boolean" } }, "additionalProperties": false },
      "outputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object" },
      "invocation": { "method": "POST", "path": "/api/v1/transcribe-audio" },
      "sideEffects": ["read-sensitive", "network", "consume-resource", "credential-use", "write-provider-files"],
      "riskClass": "external-resource",
      "approvalClass": "sensitive-content",
      "progress": { "mode": "none" },
      "cancellation": { "supported": false },
      "artifacts": [{ "role": "output", "kinds": ["text", "transcript"], "mimeTypes": ["text/plain", "application/json"], "deliveryModes": ["inline", "provider-path"] }]
    },
    {
      "id": "media.models.list",
      "revision": "1",
      "title": "List cached media models",
      "description": "Read the normalized media-model catalog currently cached by Venice Media Local.",
      "inputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "additionalProperties": false },
      "outputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object" },
      "invocation": { "method": "GET", "path": "/api/v1/state", "responseField": "models" },
      "sideEffects": ["read-local"],
      "riskClass": "read-only",
      "approvalClass": "none",
      "progress": { "mode": "none" },
      "cancellation": { "supported": false },
      "artifacts": []
    },
    {
      "id": "media.models.refresh",
      "revision": "1",
      "title": "Refresh media models",
      "description": "Refresh Venice's model catalog and update the provider-local normalized cache.",
      "inputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "additionalProperties": false },
      "outputSchema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object" },
      "invocation": { "method": "POST", "path": "/api/v1/refresh-models" },
      "sideEffects": ["network", "credential-use", "write-provider-files"],
      "riskClass": "reversible-local-write",
      "approvalClass": "none",
      "progress": { "mode": "none" },
      "cancellation": { "supported": false },
      "artifacts": []
    }
  ]
}
