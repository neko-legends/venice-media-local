{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nekolegends.com/schemas/media-sidecar.v1.schema.json",
  "title": "Neko Media Sidecar v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "schemaVersion", "app", "kind", "createdAt"],
  "properties": {
    "schema": {
      "const": "nekolegends.media-sidecar"
    },
    "schemaVersion": {
      "const": 1
    },
    "app": {
      "type": "string",
      "minLength": 1
    },
    "appVersion": {
      "type": ["string", "null"]
    },
    "kind": {
      "enum": ["image", "edit", "video", "audio", "sfx", "voice", "transcript", "atlas"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "mimeType": {
      "type": ["string", "null"]
    },
    "prompt": {
      "type": ["string", "null"]
    },
    "negativePrompt": {
      "type": ["string", "null"]
    },
    "model": {
      "type": ["string", "null"]
    },
    "seed": {
      "type": ["string", "number", "integer", "null"]
    },
    "sampler": {
      "type": ["string", "null"]
    },
    "steps": {
      "type": ["integer", "null"]
    },
    "cfgScale": {
      "type": ["number", "null"]
    },
    "variantIndex": {
      "type": ["integer", "null"]
    },
    "title": {
      "type": ["string", "null"]
    },
    "durationSeconds": {
      "type": ["number", "null"]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "byteSize": {
      "type": "integer",
      "minimum": 0
    },
    "media": {
      "type": "object",
      "properties": {
        "width": { "type": ["integer", "null"], "minimum": 1 },
        "height": { "type": ["integer", "null"], "minimum": 1 },
        "durationSeconds": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "providerArtifactId": {
      "type": "string",
      "pattern": "^vml-artifact-[a-f0-9]+$"
    },
    "providerOperationId": {
      "type": "string",
      "pattern": "^vml-op-[a-f0-9]+$"
    },
    "modelCatalogRevision": {
      "type": ["string", "null"]
    },
    "controls": {
      "type": "object"
    },
    "sourceArtifacts": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "object",
        "required": ["sha256", "relationship"],
        "properties": {
          "coreArtifactId": { "type": ["string", "null"] },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "relationship": { "enum": ["source", "mask", "reference", "first-frame", "source-video", "source-audio", "derived-from"] }
        },
        "additionalProperties": false
      }
    },
    "recipe": {
      "type": "object",
      "required": ["controlsDigest"],
      "properties": {
        "prompt": { "type": ["string", "null"] },
        "model": { "type": ["string", "null"] },
        "controlsDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "sourceFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "raw": {
      "type": "object",
      "properties": {
        "summary": { "type": "object" },
        "omittedMetadataSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    }
  }
}
